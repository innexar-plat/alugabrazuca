# ==============================================================================
# Configuração da Plataforma
# ==============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no repositório — apenas .env.example.
# ==============================================================================

# ------------------------------------------------------------------------------
# App — Identidade e ambiente
# ------------------------------------------------------------------------------
APP_NAME=AlugaBrazuca
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
APP_PORT=3000
API_PORT=3001

# Idioma padrão (pt | en | es)
APP_DEFAULT_LOCALE=pt

# ------------------------------------------------------------------------------
# Database — PostgreSQL 16
# ------------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=alugabrazuca
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=alugabrazuca_dev

# Prisma connection string (montada a partir das variáveis acima em Docker)
DATABASE_URL=postgresql://alugabrazuca:change_me_in_production@localhost:5432/alugabrazuca_dev?schema=public

# ------------------------------------------------------------------------------
# Redis 7
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# URL completa (alternativa)
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# JWT — Autenticação
# ------------------------------------------------------------------------------
JWT_SECRET=change_me_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_me_refresh_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d

# ------------------------------------------------------------------------------
# Google OAuth
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ------------------------------------------------------------------------------
# Storage — MinIO (dev) / S3 (prod)
# ------------------------------------------------------------------------------
STORAGE_PROVIDER=minio

# MinIO (desenvolvimento)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=alugabrazuca-media
MINIO_USE_SSL=false

# AWS S3 (produção — preencher quando for deploy)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_CLOUDFRONT_URL=

# ------------------------------------------------------------------------------
# Stripe — Pagamentos
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# ------------------------------------------------------------------------------
# E-mail — Resend
# ------------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@alugabrazuca.com

# ------------------------------------------------------------------------------
# SMS — Twilio
# ------------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ------------------------------------------------------------------------------
# Mapas — Mapbox
# ------------------------------------------------------------------------------
MAPBOX_ACCESS_TOKEN=

# Variável pública para o frontend Next.js
NEXT_PUBLIC_MAPBOX_TOKEN=

# ------------------------------------------------------------------------------
# Next.js — Variáveis públicas (expostas ao browser)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=AlugaBrazuca
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_LOCALE=pt

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ------------------------------------------------------------------------------
# Bcrypt
# ------------------------------------------------------------------------------
BCRYPT_SALT_ROUNDS=12

# ------------------------------------------------------------------------------
# Nginx (produção)
# ------------------------------------------------------------------------------
# DOMAIN=alugabrazuca.com
# SSL_EMAIL=admin@alugabrazuca.com
